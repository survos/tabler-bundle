{% extends 'base.html.twig' %}

{% block page_title %}Tabler Bundle Demo{% endblock %}
{% block page_subtitle %}Canonical base layout plus slot listeners, with no app-side chrome overrides.{% endblock %}

{% block body %}
    <div class="demo-grid">
        <article class="demo-card">
            <h3>Admin Hierarchy</h3>
            <p>Use tenants, intakes, and images to test hierarchy-driven breadcrumbs and page actions.</p>
            <p><a href="{{ path('app_tenants') }}">Browse tenants</a></p>
        </article>
        <article class="demo-card">
            <h3>Collection Hierarchy</h3>
            <p>Use museums and epochs to validate a second content tree with different labels.</p>
            <p><a href="{{ path('app_museums') }}">Browse museums</a></p>
        </article>
        <article class="demo-card">
            <h3>Utility Slots</h3>
            <p>Topbar utilities, auth, search, footer links, and page actions are all listener-driven.</p>
            <p><a href="{{ path('app_search') }}">Open search page</a></p>
        </article>
    </div>
{% endblock %}
