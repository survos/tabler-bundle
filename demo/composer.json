{
    "name": "survos/tabler-bundle-demo",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "survos/tabler-bundle": "*",
        "symfony/asset": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/security-bundle": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "..",
            "options": {
                "symlink": true
            }
        }
    ],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "extra": {
        "symfony": {
            "require": "^8.0"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
