{# templates/components/ui/card-title.html.twig v4.8 #}
<div class="d-flex">
   <h3 class="card-title{% if class %} {{ class }}{% endif %}">
      {{ text | default(title) | default('Card title') }}
   </h3>
   {% if more %}
   <div class="ms-auto">
      <twig:ui:button icon="dots" size="sm"/>
   </div>
   {% endif %}
</div>

