{# templates/components/cards/tabs.html.twig #}
{#
  Renders a Bootstrap tab card.
  The nav is generated from the `tabs` array.
  Tab pane content is passed as the component body (inner HTML) via the _content block.

  Usage:
    <twig:cards:tabs id="my-tabs" :tabs="[
        {id: 'ocr',     label: 'OCR'},
        {id: 'details', label: 'Details', icon: 'list'},
        {id: 'tasks',   label: 'Tasks',   badge: '3'},
    ]" activeTab="ocr" :hashNavigation="true">
        <div id="my-tabs-ocr"     class="tab-pane active show" role="tabpanel">...</div>
        <div id="my-tabs-details" class="tab-pane" role="tabpanel">...</div>
        <div id="my-tabs-tasks"   class="tab-pane" role="tabpanel">...</div>
    </twig:cards:tabs>

  Tab id convention: {id}-{tab.id}
#}

{# ── Fallback: fixture demo if no tabs array passed (legacy usage) ─────────── #}
{% if not tabs or tabs is empty %}
  <div class="card">
    <div class="card-header">
      <ul class="nav nav-tabs card-header-tabs" data-bs-toggle="tabs">
        <li class="nav-item"><a href="#tabs-home-{{ id }}" class="nav-link active" data-bs-toggle="tab">Home</a></li>
        <li class="nav-item"><a href="#tabs-profile-{{ id }}" class="nav-link" data-bs-toggle="tab">Profile</a></li>
      </ul>
    </div>
    <div class="card-body">
      <div class="tab-content">
        <div class="tab-pane active show" id="tabs-home-{{ id }}"><h4>Home tab</h4><p class="text-muted">Pass a <code>tabs</code> array to use this component.</p></div>
        <div class="tab-pane" id="tabs-profile-{{ id }}"><h4>Profile tab</h4></div>
      </div>
    </div>
  </div>
{% else %}

{% set activeId = activeTab ?? (tabs|first).id ?? '' %}

<div class="card" data-tabs-id="{{ id }}"{% if hashNavigation %} data-tabs-hash-navigation="true"{% endif %}>
  <div class="card-header">
    <ul class="nav nav-tabs card-header-tabs{% if reverse %} flex-row-reverse{% endif %}{% if justified %} nav-fill{% endif %}"
        id="{{ id }}-nav"
        data-bs-toggle="tabs"
        role="tablist">
      {% for tab in tabs %}
        {% set tabId = id ~ '-' ~ tab.id %}
        {% set isActive = tab.id == activeId %}
        <li class="nav-item" role="presentation">
          <a href="#{{ tabId }}"
             id="{{ tabId }}-tab"
             class="nav-link{% if isActive %} active{% endif %}"
             data-bs-toggle="tab"
             data-tab-id="{{ tab.id }}"
             role="tab"
             aria-controls="{{ tabId }}"
             aria-selected="{{ isActive ? 'true' : 'false' }}"
             {% if not isActive %}tabindex="-1"{% endif %}>
            {% if tab.icon is defined and tab.icon %}
              <twig:ui:icon :icon="tab.icon" class="me-1"/>
            {% endif %}
            {{ tab.label }}
            {% if tab.badge is defined and tab.badge %}
              <span class="badge bg-secondary-lt ms-1">{{ tab.badge }}</span>
            {% endif %}
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="card-body">
    <div class="tab-content" id="{{ id }}-content">
      {% block _content %}{% endblock %}
    </div>
  </div>
</div>

{% if hashNavigation %}
<script>
(function () {
  var nav = document.getElementById({{ (id ~ '-nav')|json_encode }});
  if (!nav) return;
  var hash = location.hash.slice(1);
  if (hash) {
    var link = nav.querySelector('[data-tab-id="' + hash + '"]');
    if (link) bootstrap.Tab.getOrCreateInstance(link).show();
  }
  nav.addEventListener('shown.bs.tab', function (e) {
    var tabId = e.target.getAttribute('data-tab-id');
    if (tabId) history.replaceState(null, '', '#' + tabId);
  });
})();
</script>
{% endif %}

{% endif %}
