<!DOCTYPE html{% block html_start %}{% endblock %}>
<html lang="{{ app.request.locale|default('en') }}">
<head>
    {% block head %}
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    {% endblock %}

    {% set _page = page_context() %}
    {% set _routeName = app.request ? app.request.attributes.get('_route', 'home.title') : 'home.title' %}
    {% set _routeTitle = _routeName|trans({}, 'routing') %}
    {% set _blockTitle = block('page_title') is defined ? block('page_title')|trim : '' %}
    {% set _blockPretitle = block('page_pretitle') is defined ? block('page_pretitle')|trim : '' %}
    {% set _blockSubtitle = block('page_subtitle') is defined ? block('page_subtitle')|trim : '' %}
    {% set resolvedPageTitle = _page.title|default(_blockTitle ?: _routeTitle) %}
    {% set resolvedPagePretitle = _page.pretitle|default(_blockPretitle ?: null) %}
    {% set resolvedPageSubtitle = _page.subtitle|default(_blockSubtitle ?: null) %}
    {% set containerClass = _page.container_class|default('container-xl') %}
    {% set showPageHeader = _page.show_page_header is defined ? _page.show_page_header : (resolvedPageTitle or tabler_menu_has_items(BREADCRUMB) or tabler_menu_has_items(PAGE_NAV) or tabler_menu_has_items(PAGE_ACTIONS)) %}

    <title>{% block title %}{{ resolvedPageTitle|striptags|trim }}{% endblock %}</title>

    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('favicon-32x32.png') }}">
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('favicon-16x16.png') }}">
        <link rel="manifest" href="{{ asset('site.webmanifest') }}">
    {% endblock %}

    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>
{% block body_start_tag %}
<body {% block body_start %}{% endblock %} class="{% block body_class %}{% endblock %}">
{% endblock %}
{% block after_body_start %}{% endblock %}
{% block logo_path %}{% endblock %}
{% block page_pretitle %}{% endblock %}
{% block page_subtitle %}{% endblock %}
{% set id = tabler_identity ?? {} %}
{% set showSidebar = tabler_menu_has_items(SIDEBAR) %}
{% set debugMenuSlots = tabler_menu_debug_enabled() %}

{% set brandHref %}
    {% if block('logo_path')|trim %}
        {{ block('logo_path') }}
    {% elseif id.homepage_route is defined and id.homepage_route %}
        {{ path(id.homepage_route) }}
    {% elseif id.homepage_url is defined and id.homepage_url %}
        {{ id.homepage_url }}
    {% else %}
        {{ path('app_homepage') }}
    {% endif %}
{% endset %}

{% block banner %}
    {% if tabler_menu_has_items(BANNER) %}
        <div class="tblr-banner">
            {{ component('tabler:menu', {type: BANNER, caller: _self}) }}
            <div class="tblr-banner-close" data-bs-dismiss="alert">{{ ux_icon('tabler:x') }}</div>
        </div>
    {% endif %}
{% endblock %}

{% block debug_menu_slots %}
    {% if debugMenuSlots %}
        <style>
            .tabler-debug-slot {
                border: 2px solid rgba(220, 53, 69, .75);
                border-radius: .5rem;
                padding: .35rem;
            }
            .tabler-debug-slot-label {
                display: inline-block;
                margin-bottom: .35rem;
                color: #b42318;
                font-size: .7rem;
                font-weight: 700;
                letter-spacing: .04em;
                text-transform: uppercase;
            }
            .tabler-debug-badge {
                display: inline-flex;
                align-items: center;
                gap: .35rem;
                border-radius: 999px;
                background: rgba(220, 53, 69, .12);
                border: 1px solid rgba(220, 53, 69, .35);
                color: #b42318;
                font-size: .72rem;
                font-weight: 700;
                letter-spacing: .04em;
                line-height: 1;
                padding: .35rem .6rem;
                text-transform: uppercase;
                white-space: nowrap;
            }
            .tabler-debug-badge .icon {
                width: .9rem;
                height: .9rem;
            }
        </style>
    {% endif %}
{% endblock %}

<div class="page">
    {{ block('debug_menu_slots') }}
    {% block navbar %}
        <header class="navbar navbar-expand-md d-print-none">
            <div class="{{ containerClass }}">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-menu" aria-controls="navbar-menu" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-brand navbar-brand-autodark d-none-navbar-horizontal pe-0 pe-md-3">
                    <a href="{{ brandHref|trim }}">
                        {% block logo_mini %}
                            {% if id.logo_small is defined and id.logo_small %}
                                <img src="{{ id.logo_small }}" class="navbar-brand-image" height="32" alt="{{ id.title|default('') }}">
                            {% elseif id.logo is defined and id.logo %}
                                <img src="{{ id.logo }}" class="navbar-brand-image" height="32" alt="{{ id.title|default('') }}">
                            {% else %}
                                <img src="{{ asset('favicon-32x32.png') }}" class="navbar-brand-image" height="32" alt="{{ id.title|default('') }}">
                            {% endif %}
                            {% block logo_large %}
                                <span class="ms-2">{{ id.abbr|default(id.title|default('Tabler'))|raw }}</span>
                            {% endblock %}
                        {% endblock %}
                    </a>
                </div>

                <div class="navbar-nav flex-row order-md-last ms-auto">
                    {% for slot in [NAVBAR_THEME, NAVBAR_NOTIFICATIONS, NAVBAR_APPS, NAVBAR_LANGUAGE, NAVBAR_END, SEARCH, AUTH] %}
                        {% if debugMenuSlots or tabler_menu_has_items(slot) %}
                            <div class="{% if debugMenuSlots %}tabler-debug-slot ms-2{% endif %}">
                                {% if debugMenuSlots %}<div class="tabler-debug-slot-label">{{ slot }}</div>{% endif %}
                                {% if tabler_menu_has_items(slot) %}
                                    {{ component('tabler:menu', {type: slot, caller: _self}) }}
                                {% endif %}
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </header>
    {% endblock %}

    {% block navbar_secondary %}
        {% if tabler_menu_has_items(NAVBAR_START) or tabler_menu_has_items(NAVBAR_MENU) or tabler_menu_has_items(NAVBAR_MENU_END) %}
            <header class="navbar-expand-md">
                <div class="collapse navbar-collapse" id="navbar-menu">
                    <div class="navbar">
                        <div class="{{ containerClass }}">
                            <div class="row flex-column flex-md-row flex-fill align-items-center">
                                <div class="col">
                                    {% if debugMenuSlots or tabler_menu_has_items(NAVBAR_START) %}
                                        <div class="{% if debugMenuSlots %}tabler-debug-slot mb-2{% endif %}">
                                            {% if debugMenuSlots %}<div class="tabler-debug-slot-label">NAVBAR_START</div>{% endif %}
                                            {% if tabler_menu_has_items(NAVBAR_START) %}
                                                {{ component('tabler:menu', {type: NAVBAR_START, caller: _self}) }}
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    {% if debugMenuSlots or tabler_menu_has_items(NAVBAR_MENU) %}
                                        <div class="{% if debugMenuSlots %}tabler-debug-slot{% endif %}">
                                            {% if debugMenuSlots %}<div class="tabler-debug-slot-label">NAVBAR_MENU</div>{% endif %}
                                            {% if tabler_menu_has_items(NAVBAR_MENU) %}
                                                {{ component('tabler:menu', {type: NAVBAR_MENU, caller: _self}) }}
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                                <div class="col col-md-auto">
                                    {% if debugMenuSlots or tabler_menu_has_items(NAVBAR_MENU_END) %}
                                        <div class="{% if debugMenuSlots %}tabler-debug-slot{% endif %}">
                                            {% if debugMenuSlots %}<div class="tabler-debug-slot-label">NAVBAR_MENU_END</div>{% endif %}
                                            {% if tabler_menu_has_items(NAVBAR_MENU_END) %}
                                                {{ component('tabler:menu', {type: NAVBAR_MENU_END, caller: _self}) }}
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </header>
        {% endif %}
    {% endblock %}

    <div class="page-wrapper">
        {% block page_header %}
            {% if showPageHeader %}
                <div class="page-header d-print-none">
                    <div class="{{ containerClass }}">
                        <div class="row g-2 align-items-center">
                            <div class="col">
                                {% if resolvedPagePretitle %}
                                    <div class="page-pretitle">{{ resolvedPagePretitle|raw }}</div>
                                {% endif %}
                                {% if tabler_menu_has_items(BREADCRUMB) %}
                                    <div class="page-pretitle {% if debugMenuSlots %}tabler-debug-slot{% endif %}">
                                        {% if debugMenuSlots %}<div class="tabler-debug-slot-label">BREADCRUMB</div>{% endif %}
                                        {{ component('tabler:menu', {type: BREADCRUMB, caller: _self}) }}
                                    </div>
                                {% endif %}
                                {% if resolvedPageTitle %}
                                    <h2 class="page-title">
                                        {% block back_link %}{% endblock %}
                                        {{ resolvedPageTitle|raw }}
                                    </h2>
                                {% endif %}
                                {% if resolvedPageSubtitle %}
                                    <div class="text-secondary mt-1">{{ resolvedPageSubtitle|raw }}</div>
                                {% endif %}
                            </div>
                            {% if debugMenuSlots or tabler_menu_has_items(PAGE_ACTIONS) %}
                                <div class="col-auto ms-auto d-print-none {% if debugMenuSlots %}tabler-debug-slot{% endif %}">
                                    {% if debugMenuSlots %}<div class="tabler-debug-slot-label">PAGE_ACTIONS</div>{% endif %}
                                    <div class="btn-list">
                                        {% if tabler_menu_has_items(PAGE_ACTIONS) %}
                                            {{ component('tabler:menu', {type: PAGE_ACTIONS, caller: _self, options: {title: resolvedPageTitle}}) }}
                                        {% endif %}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                        {% if debugMenuSlots or tabler_menu_has_items(PAGE_NAV) %}
                            <div class="mt-3 {% if debugMenuSlots %}tabler-debug-slot{% endif %}">
                                {% if debugMenuSlots %}<div class="tabler-debug-slot-label">PAGE_NAV</div>{% endif %}
                                <ul class="nav nav-tabs nav-pills border rounded-3 p-2 gap-1">
                                    {% if tabler_menu_has_items(PAGE_NAV) %}
                                        {{ component('tabler:menu', {type: PAGE_NAV, caller: _self, options: {title: resolvedPageTitle}}) }}
                                    {% endif %}
                                </ul>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        {% endblock %}

        {% block page_content_before %}
            {% block page_navigation %}{% endblock %}
        {% endblock %}

        <div class="page-body">
            <div class="{{ containerClass }}">
                {% block page_content_start %}
                    {{ include('@SurvosTabler/Partials/_flash_messages.html.twig') }}
                {% endblock %}

                <div class="row">
                    {% if showSidebar %}
                        <aside class="col-12 col-lg-3 col-xl-2 mb-4 d-print-none">
                            {% block sidebar %}
                                <div class="card {% if debugMenuSlots %}tabler-debug-slot{% endif %}">
                                    {% if debugMenuSlots %}<div class="tabler-debug-slot-label">SIDEBAR</div>{% endif %}
                                    <div class="card-body p-0">
                                        {% include '@SurvosTabler/render_sidebar_menu.html.twig' with {menuCode: SIDEBAR} %}
                                    </div>
                                </div>
                            {% endblock %}
                        </aside>
                    {% endif %}

                    <div class="{% if showSidebar %}col-12 col-lg-9 col-xl-10{% else %}col-12{% endif %}">
                        <section class="{% block page_content_class %}content{% endblock %}">
                            {% block page_content %}
                                {% block body %}{% endblock %}
                            {% endblock %}
                        </section>
                    </div>
                </div>
            </div>
        </div>

        {% block footer %}
            {% if debugMenuSlots or tabler_menu_has_items(FOOTER) or tabler_menu_has_items(FOOTER_END) %}
                <footer class="footer footer-transparent d-print-none">
                    <div class="{{ containerClass }}">
                        <div class="row text-center align-items-center flex-row-reverse">
                            <div class="col-lg-auto ms-lg-auto">
                                {% if debugMenuSlots or tabler_menu_has_items(FOOTER_END) %}
                                    <div class="{% if debugMenuSlots %}tabler-debug-slot d-inline-block{% endif %}">
                                        {% if debugMenuSlots %}<div class="tabler-debug-slot-label">FOOTER_END</div>{% endif %}
                                        {% if tabler_menu_has_items(FOOTER_END) %}
                                            {{ component('tabler:menu', {type: FOOTER_END, caller: _self}) }}
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                            <div class="col-lg-auto me-lg-auto">
                                {% if debugMenuSlots or tabler_menu_has_items(FOOTER) %}
                                    <div class="{% if debugMenuSlots %}tabler-debug-slot d-inline-block{% endif %}">
                                        {% if debugMenuSlots %}<div class="tabler-debug-slot-label">FOOTER</div>{% endif %}
                                        {% if tabler_menu_has_items(FOOTER) %}
                                            {{ component('tabler:menu', {type: FOOTER, caller: _self}) }}
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </footer>
            {% endif %}
        {% endblock %}
    </div>
</div>
{% block body_end %}{% endblock %}
</body>
</html>
