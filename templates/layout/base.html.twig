{% extends '@SurvosTabler/base.html.twig' %}

{% do page({
    defaults: {
        container: layout|default('horizontal') == 'fluid' ? 'fluid' : 'xl'
    }
}, _self) %}

{% block stylesheets %}{% endblock %}

{% block javascripts %}
    {{ importmap('app') }}
{% endblock %}

{% block body_class %}
    {{ parent() }}{% if layout|default('horizontal') == 'boxed' %} layout-boxed{% endif %}
{% endblock %}

{% block page_navigation %}
    {% block breadcrumb %}{% endblock %}
{% endblock %}

{% block body %}
    {% block content %}{% endblock %}
{% endblock %}
