{% extends '@SurvosTabler/base.html.twig' %}

{% block stylesheets %}{% endblock %}

{% block javascripts %}
    {{ importmap('app') }}
{% endblock %}

{% block container_class %}
    {{ layout|default('horizontal') == 'fluid' ? 'container-fluid' : 'container-xl' }}
{% endblock %}

{% block body_class %}
    {{ parent() }}{% if layout|default('horizontal') == 'boxed' %} layout-boxed{% endif %}
{% endblock %}

{% block page_navigation %}
    {% block breadcrumb %}{% endblock %}
{% endblock %}

{% block body %}
    {% block content %}{% endblock %}
{% endblock %}
