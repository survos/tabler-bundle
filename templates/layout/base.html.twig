{# @SurvosTabler/layout/base.html.twig v2.0 - Base layout with all blocks #}
{#
    Layouts: horizontal, sidebar, combo, navbar-overlap, navbar-dark, fluid, boxed, landing

    Usage:
    {% extends "@SurvosTabler/layout/base.html.twig" %}
    {% set layout = 'sidebar' %}
    {% block content %}...{% endblock %}
#}

{% set layout = layout|default('horizontal') %}
{% set containerClass = layout == 'fluid' ? 'container-fluid' : 'container-xl' %}
{% set showNavbar = layout not in ['landing'] %}
{% set showSidebar = layout in ['sidebar', 'combo'] %}
{% set showNavbarMenu = layout in ['horizontal', 'combo', 'navbar-overlap'] %}
{% set showFooter = showFooter|default(true) %}
{% set _blockPagePretitle %}{% block page_pretitle %}{% endblock %}{% endset %}
{% set _blockPageTitle %}{% block page_title %}{% endblock %}{% endset %}
{% set _blockPageSubtitle %}{% block page_subtitle %}{% endblock %}{% endset %}

<!doctype html>
<html lang="{{ app.request.locale|default('en') }}"{% if layout == 'rtl' %} dir="rtl"{% endif %}>
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
    <meta http-equiv="X-UA-Compatible" content="ie=edge"/>
    <title>{% block title %}{{ (_blockPageTitle|trim ?: page_context().title|default(pageTitle|default(app.request.attributes.get('_route')|default('Tabler')))) ?: 'Tabler' }}{% endblock %}</title>

    {% block meta %}
        <meta name="description" content="{% block meta_description %}{% endblock %}">
    {% endblock %}

    {% block stylesheets %}{% endblock %}

    {% block head %}{% endblock %}
</head>

<body class="{% block body_class %}{% if layout == 'boxed' %}layout-boxed{% endif %}{% endblock %}">
    {% block body_start %}{% endblock %}

    {# === BANNER (promotional/announcements) === #}
    {% block banner %}{% endblock %}

    <div class="page">
        {# === TOP NAVBAR === #}
        {% if showNavbar %}
        <style>
            .page .navbar-toggler-icon {
                height: 1.5px;
                width: 1em;
            }
            .page .navbar-toggler-icon:before {
                top: -0.325em;
            }
            .page .navbar-toggler-icon:after {
                bottom: -0.35em;
            }
        </style>
        {% block navbar %}
        <header class="navbar navbar-expand-md {% if layout == 'navbar-dark' %} navbar-dark {% endif %} {% if layout == 'navbar-overlap' %} navbar-overlap {% endif %}">
            <div class="{{ containerClass }}">
                <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navbar-menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                {# Brand/Logo #}
                {% block navbar_brand %}
                {% set id = tabler_identity ?? {} %}
                <h1 class="navbar-brand navbar-brand-autodark">
                    <a href="{{ id.homepage_route is defined and id.homepage_route ? path(id.homepage_route) : (id.homepage_url is defined and id.homepage_url ? id.homepage_url : path('app_homepage')) }}" class="text-decoration-none">
                        {% block brand %}
                            {% if id.logo_small ?? id.logo %}
                                <img src="{{ id.logo_small ?? id.logo }}" class="navbar-brand-image" height="32" alt="{{ id.title|default('') }}">
                            {% else %}
                                {{ ux_icon('brand', {height: 32, width: 32, class: 'navbar-brand-image text-primary'}) }}
                                <span class="d-none d-sm-inline align-middle ms-1 fs-3 fw-bolder">{% block brand_text %}{{ (id.abbr ?? id.title ?? 'Survos')|raw }}{% endblock %}</span>
                            {% endif %}
                        {% endblock %}
                    </a>
                </h1>
                {% endblock %}

                {# Right side: search, notifications, user menu #}
                <div class="navbar-nav align-items-center" style="min-height: auto;">
                    {% block navbar_search %}
                        {# Search form or icon #}
                    {% endblock %}

                    {% block navbar_notifications %}
                        {# Notification dropdown #}
                    {% endblock %}

                    {% block navbar_end %}
                        {# Additional navbar items #}
                    {% endblock %}

                    {% block navbar_auth %}
                        {% if app.user %}
                        <div class="dropdown">
                            <button type="button" class="btn btn-sm dropdown-toggle" data-bs-toggle="dropdown">
                                <span class="avatar avatar-xs rounded-pill shadow-none fw-bolder text-bg-primary" style="--tblr-avatar-font-size: 0.725rem;">{{ app.user.email|slice(0,1)|upper }}</span>
                                <span class="ms-1">{{ app.user.email }}</span>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end">
                                {% block user_menu %}
                                    <a href="{{ path('app_homepage') }}" class="dropdown-item small">
                                        {{ ux_icon('user') }}
                                        <span class="ms-1">Profile</span>
                                    </a>
                                    <a href="{{ path('app_logout') }}" class="dropdown-item small">
                                        {{ ux_icon('logout') }}
                                        <span class="ms-1">Logout</span>
                                    </a>
                                {% endblock %}
                            </div>
                        </div>
                        {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-sm btn-primary">
                            {{ ux_icon('login') }}
                            <span class="ms-1">Login</span>
                        </a>
                        {% endif %}
                    {% endblock %}
                </div>
            </div>
        </header>
        {% endblock %}
        {% endif %}

        {# === HORIZONTAL NAV MENU (below top navbar) === #}
        {% if showNavbarMenu %}
        <style>
            #navbar-menu .navbar-nav .nav-item {
                white-space: nowrap;
            }
        </style>
        {% block navbar_menu %}
        <header class="navbar-expand-md">
            <div id="navbar-menu" class="collapse navbar-collapse">
                <div class="navbar">
                    <div class="{{ containerClass }}">
                        <ul class="navbar-nav">
                            {% block navbar_menu_items %}
                                {{ component('tabler:menu', {type: NAVBAR_MENU, caller: _self}) }}
                            {% endblock %}
                        </ul>
                    </div>
                </div>
            </div>
        </header>
        {% endblock %}
        {% endif %}

        {# === PAGE WRAPPER (sidebar + content) === #}
        <div class="page-wrapper">
            {# === SIDEBAR === #}
            {% if showSidebar %}
            {% block sidebar %}
            <aside class="navbar navbar-vertical navbar-expand-lg{% if layout == 'navbar-dark' %} navbar-dark{% endif %}">
                <div class="container-fluid">
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu" aria-controls="sidebar-menu" aria-expanded="false" aria-label="Toggle sidebar">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    {% block sidebar_brand %}
                    {% set id = tabler_identity ?? {} %}
                    <h1 class="navbar-brand navbar-brand-autodark">
                        <a href="{{ id.homepage_route is defined and id.homepage_route ? path(id.homepage_route) : (id.homepage_url is defined and id.homepage_url ? id.homepage_url : path('app_homepage')) }}">
                            {% if id.logo_small ?? id.logo %}
                                <img src="{{ id.logo_small ?? id.logo }}" class="navbar-brand-image" height="32" alt="{{ id.title|default('') }}">
                            {% else %}
                                {{ ux_icon('tabler:brand-tabler', {height: 32}) }}
                            {% endif %}
                            <span class="ms-2">{{ (id.abbr ?? id.title ?? 'Tabler')|raw }}</span>
                        </a>
                    </h1>
                    {% endblock %}

                    <div class="collapse navbar-collapse" id="sidebar-menu">
                        <ul class="navbar-nav pt-lg-3">
                            {% block sidebar_menu_items %}
                                {{ component('tabler:menu', {type: SIDEBAR, caller: _self}) }}
                            {% endblock %}
                        </ul>
                    </div>
                </div>
            </aside>
            {% endblock %}
            {% endif %}

            {# --- MAIN CONTENT --- #}
            <div class="page-body">
                <div class="{{ containerClass }}">
                    {# Page Header #}
                    {% set _page = page_context() %}
                    {% set _pageTitle = _blockPageTitle|trim ?: _page.title|default(pageTitle|default(app.request.attributes.get('_route')|default(''))) %}
                    {% set _pagePretitle = _blockPagePretitle|trim ?: _page.pretitle|default('') %}
                    {% set _pageSubtitle = _blockPageSubtitle|trim ?: _page.subtitle|default('') %}
                    {% set _showPageHeader = _page.show_page_header ?? showPageHeader ?? true %}
                    {% if _showPageHeader %}
                        {% block page_header %}
                            <div class="page-header mb-4 mt-0 border-bottom pb-3">
                                <div class="container-fluid">
                                    {% if _pagePretitle %}
                                        <div class="page-pretitle text-primary fw-semibold text-uppercase">{{ _pagePretitle|raw }}</div>
                                    {% endif %}
                                    <h2 class="page-title fw-bolder text-dark mb-1">
                                        {{ _pageTitle|raw }}
                                    </h2>
                                    {% if _pageSubtitle %}
                                        <div class="text-secondary mt-1 small">{{ _pageSubtitle|raw }}</div>
                                    {% endif %}
                                </div>
                            </div>
                        {% endblock %}
                    {% endif %}

                    {% block page_actions %}
                        {% if tabler_menu_has_items(PAGE_ACTIONS) %}
                            <div id="page-actions" class="mb-3">
                                <ul class="nav nav-tabs nav-pill border p-2 rounded-2 gap-1">
                                    {{ component('tabler:menu', {type: PAGE_ACTIONS, caller: _self}) }}
                                </ul>
                            </div>
                        {% endif %}
                    {% endblock %}

                    {# Breadcrumb #}
                    {% block breadcrumb %}{% endblock %}

                    {# Flash Messages #}
                    {% block flashes %}
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible" role="alert">
                                <div class="d-flex">
                                    <div>{{ message }}</div>
                                </div>
                                <a class="btn-close" data-bs-dismiss="alert" aria-label="Close"></a>
                            </div>
                        {% endfor %}
                    {% endfor %}
                    {% endblock %}

                    {# Main Content #}
                    {% block content %}{% endblock %}
                </div>
            </div>

            {# --- FOOTER --- #}
            {% if showFooter %}
                <footer class="footer py-3">
                    <div class="{{ containerClass }}">
                        {% block footer %}
                            {% block footer_links %}{% endblock %}
                            <div class="text-center text-muted">
                            {% block footer_copyright %}
                                <div>Copyright &copy; {{ 'now'|date('Y') }} <a href="." class="text-decoration-none">{{ block('brand_text') }}</a>. All Rights Reserved.</div>
                            {% endblock %}
                        {% endblock %}
                    </div>
                </footer>
            {% endif %}
        </div>
    </div>

    {# --- MODALS --- #}
    {% block modals %}{% endblock %}

    {# --- SCRIPTS --- #}
    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}

    {% block body_end %}{% endblock %}
</body>

</html>
